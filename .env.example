APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3001

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Reverb (realtime WebSocket). Local dev runs it as its own docker service named
# "reverb" (see compose.yaml, restart: unless-stopped). The Laravel app publishes events
# to it over the docker network, so REVERB_HOST is the SERVICE NAME (not 127.0.0.1) —
# using 127.0.0.1 makes every broadcast 500 now that Reverb is a separate container.
# The browser connects from the host via localhost:8080; set the MATCHING
# NEXT_PUBLIC_REVERB_* (same app key!) in yondra-frontend/.env.local.
REVERB_APP_ID=yondra-local
REVERB_APP_KEY=yondra-local-key
REVERB_APP_SECRET=yondra-local-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
# The reverb server binds all interfaces so the published port is reachable from the host.
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Only used by a Vite frontend — this repo's frontend is Next.js and ignores these.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="localhost"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

VORTEX_ADMIN_EMAILS=

# Vortex Anomalies error monitor (YON-74). Backend exception capture is on by
# default (ERROR_MONITOR_ENABLED). To also ingest browser errors, set a shared
# secret here and expose the SAME value to the frontend as NEXT_PUBLIC_TELEMETRY_TOKEN;
# leaving it blank keeps the /api/webhooks/errors ingest endpoint closed (404).
ERROR_MONITOR_ENABLED=true
ERROR_MONITOR_OCCURRENCE_CAP=50
TELEMETRY_INGEST_TOKEN=

# GIF picker in the comment composer (Tenor). Optional — with no key the GIF
# button is hidden and /api/gifs/search answers 503. Free key: Google Cloud console.
TENOR_API_KEY=

# Card AI assist (streamed thread summaries). Provider-agnostic — AI_DRIVER selects
# the implementation (default: anthropic). Adding a provider is a new driver class +
# a bind arm in AppServiceProvider; no env change beyond flipping AI_DRIVER. With the
# selected provider unconfigured, the "Summarise thread" button is hidden and
# /api/.../ai/summarize answers 503.
# AI_DRIVER=anthropic
# AI_MAX_TOKENS=700

# Anthropic (Claude) provider. Key from console.anthropic.com. ANTHROPIC_MODEL defaults
# to claude-opus-4-8; set claude-haiku-4-5 for cheaper, faster summaries.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# Groq provider (AI_DRIVER=groq). Key from console.groq.com. Set GROQ_MODEL to a current
# Groq-hosted model id if the default doesn't fit.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Local Ollama provider (AI_DRIVER=ollama). No key — just run `ollama serve` and pull a
# model. Defaults to http://localhost:11434/v1 and llama3.1.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1
